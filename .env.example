# ─────────────────────────────────────────────────────────────────────────────
#  PisoWise — Environment Variables
#  Copy this file to .env and fill in your actual values.
#  NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ─── Firebase ──────────────────────────────────────────────────────────────
VITE_FIREBASE_API_KEY=your-firebase-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
VITE_FIREBASE_APP_ID=your-app-id
VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# ─── FCM (Firebase Cloud Messaging) ────────────────────────────────────────
VITE_FCM_VAPID_KEY=your-vapid-key-from-firebase-console

# ─── Groq AI (Llama 3.3 70B Versatile) ────────────────────────────────────
# Get your API key from: https://console.groq.com
VITE_GROQ_API_KEY=gsk_your-groq-api-key

# ─── EmailJS (OTP Verification) ────────────────────────────────────────────
# Set up at: https://www.emailjs.com
VITE_EMAILJS_SERVICE_ID=service_xxxxxxxx
VITE_EMAILJS_TEMPLATE_ID=template_xxxxxxxx
VITE_EMAILJS_PUBLIC_KEY=your-emailjs-public-key
