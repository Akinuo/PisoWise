# ─────────────────────────────────────────────────────────────────────────────
#  PisoWise — Environment Variables
#  Copy this file to .env and fill in your actual values.
#  NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ─── Firebase ──────────────────────────────────────────────────────────────
VITE_FIREBASE_API_KEY=your-firebase-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
VITE_FIREBASE_APP_ID=your-app-id
VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX


# ─── Groq AI (Llama 3.3 70B Versatile) ────────────────────────────────────
# Get your API key from: https://console.groq.com
VITE_GROQ_API_KEY=gsk_your-groq-api-key

# Optional but recommended: deploy api/groq.js to Vercel (free tier) and set
# GROQ_API_KEY (no VITE_ prefix) there as a server-only env var. Then set
# VITE_GROQ_PROXY_URL below to that deployment's /api/groq URL. This keeps
# the real Groq key out of the client bundle entirely — Firebase's Spark
# plan has no Cloud Functions to do this on the Firebase side, so this is
# the free alternative. Leave blank to keep calling Groq directly from the
# browser with VITE_GROQ_API_KEY above (fine for development, not for real
# traffic — that key is visible to anyone who opens devtools).
VITE_GROQ_PROXY_URL=

# ─── EmailJS (OTP Verification) ────────────────────────────────────────────
# Set up at: https://www.emailjs.com
VITE_EMAILJS_SERVICE_ID=service_xxxxxxxx
VITE_EMAILJS_TEMPLATE_ID=template_xxxxxxxx
VITE_EMAILJS_PUBLIC_KEY=your-emailjs-public-key
